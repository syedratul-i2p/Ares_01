# Custom ARES-01 Ground Station exclusions
.env

# ==============================================================================
# Flutter App Exclusions (D:/ARES-01/flutter_app)
# ==============================================================================
# Miscellaneous
*.class
*.log
*.pyc
*.swp
.DS_Store
.atom/
.buildlog/
.history
.svn/
migrate_working_dir/

# IntelliJ related
*.iml
*.ipr
*.iws
.idea/

# The .vscode folder contains bare-minimum workspace folders
.vscode/

# Flutter/Dart/Pub related
